# 复制为 .env.local 后填写（.env.local 已被 gitignore，不会提交）

# ---- Web 开发环境 AI 配置 ----
# 前端 AI 请求的代理地址。
# 本地开发：先运行 `npm run dev:proxy` 启动代理，再设置为：
VITE_API_PROXY_URL=http://localhost:8787

# AI 模型 API Key（仅供 dev-ai-proxy 读取，不会打进前端 bundle）
# 主模型：DeepSeek（https://platform.deepseek.com）
DEEPSEEK_API_KEY=
# 备用模型：智谱 GLM（https://open.bigmodel.cn）
GLM_API_KEY=

# 代理监听端口（可选，默认 8787）
# AI_PROXY_PORT=8787
